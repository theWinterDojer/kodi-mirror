<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.kodi.mirror"
       name="Kodi Mirror"
       version="0.1.0"
       provider-name="dojer">
  <requires>
    <import addon="xbmc.python" version="3.0.1"/>
  </requires>
  <extension point="xbmc.python.script" library="addon.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Kodi backup and live restore addon optimized for D-pad controls.</summary>
    <description lang="en_GB">Kodi Mirror backs up the active userdata and addons roots into a ZIP archive and applies best-effort live restore with clear skipped-file reporting.</description>
    <platform>all</platform>
    <license>MIT</license>
    <source>https://github.com/theWinterDojer/kodi-mirror</source>
    <assets>
      <icon>resources/icon.png</icon>
    </assets>
    <news>Initial packaging baseline.</news>
  </extension>
</addon>
